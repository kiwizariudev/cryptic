{
    "geode": "4.10.2",
    "gd": {
        "win": "2.2074",
        "android": "2.2074",
        "mac": "2.2074",
        "ios": "2.2074"
    },
    "links": {
        "community": "link",
        "source":"https://github.com/kiwizariudev/cryptic" 
    },
    "id": "kiwizariu.cryptic",
    "name": "cryptic",
    "version": "v1.0.0",
    "developer": "kiwizariu",
	
    "description": "Practice tools.",
    "dependencies": {
        "geode.node-ids": ">=v1.20.0"
    },
    "settings": {
        "appearance": {
            "type": "title",
            "name": "Appearance"
        },
        "accent-color": {
            "type": "rgb",
            "name": "Accent Color",
            "description": "Color used for HUD values and menu highlights.",
            "default": { "r": 100, "g": 200, "b": 255 }
        },
        "hud-section": {
            "type": "title",
            "name": "HUD"
        },
        "show-fps": {
            "type": "bool",
            "name": "Show FPS",
            "default": true
        },
        "show-speed": {
            "type": "bool",
            "name": "Show Speed",
            "default": true
        },
        "show-attempts": {
            "type": "bool",
            "name": "Show Attempts",
            "default": true
        },
        "show-best-run": {
            "type": "bool",
            "name": "Show Best Run %",
            "description": "Best % reached this session (resets on level exit).",
            "default": true
        },
        "show-cps": {
            "type": "bool",
            "name": "Show CPS",
            "default": true
        },
        "cheats-section": {
            "type": "title",
            "name": "Cheats"
        },
        "noclip": {
            "type": "bool",
            "name": "Noclip",
            "description": "Player cannot die.",
            "default": false
        },
        "instant-complete": {
            "type": "bool",
            "name": "Instant Complete",
            "description": "Level completes immediately on start.",
            "default": false
        },
        "unlock-all": {
            "type": "bool",
            "name": "Unlock All Icons",
            "description": "Makes all icons, colors, and cosmetics appear unlocked.",
            "default": false
        },
        "unlock-levels": {
            "type": "bool",
            "name": "Unlock All Levels",
            "description": "Unlocks all official RobTop levels.",
            "default": false
        },
        "fake-100": {
            "type": "bool",
            "name": "Show 100% on All Levels",
            "description": "Displays 100% completion on all official levels.",
            "default": false
        },
        "show-hitbox": {
            "type": "bool",
            "name": "Show Hitbox",
            "default": false
        },
        "hitbox-on-death": {
            "type": "bool",
            "name": "Hitbox On Death",
            "description": "Briefly shows hitboxes when you die.",
            "default": false
        },
        "layout-mode": {
            "type": "bool",
            "name": "Layout Mode",
            "description": "Hides backgrounds for a cleaner editor-like view.",
            "default": false
        }
    }
}